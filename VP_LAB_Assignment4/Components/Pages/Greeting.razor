@page "/greeting"
@rendermode InteractiveServer

<PageTitle>Application 1: Greeting</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center py-3 rounded-top-4">
                    <h4 class="mb-0 fw-semibold">Interactive Greeting</h4>
                </div>
                <div class="card-body p-4">

                    <div class="mb-4">
                        <label for="userNameInput" class="form-label fw-bold text-secondary text-uppercase small">Enter Your Name</label>
                        <input type="text"
                               id="userNameInput"
                               class="form-control form-control-lg border-2 rounded-3"
                               placeholder="Type name here..."
                               @bind-value="userName"
                               @bind-value:event="oninput" />
                    </div>

                    <div class="border-top my-4"></div>

                    <div class="text-center py-3 bg-light rounded-3 border">
                        @if (string.IsNullOrWhiteSpace(userName))
                        {
                            <h2 class="text-muted fst-italic mb-0">Hello, Guest!</h2>
                        }
                        else
                        {
                            <h2 class="text-success fw-bold mb-0 text-break">Hello, @userName!</h2>
                        }
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string userName = string.Empty;
}