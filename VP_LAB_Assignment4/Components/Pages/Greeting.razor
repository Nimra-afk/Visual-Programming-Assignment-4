@page "/greeting"
@using System

<PageTitle>Application 1: Dynamic Greeting</PageTitle>

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Application 1: Time-Based Greeting</h3>
        </div>
        <div class="card-body text-center p-5">
            <h2 class="text-secondary">@GetGreetingMessage()!</h2>
            <p class="lead mt-3">The current system time is: <strong>@currentTime.ToLongTimeString()</strong></p>

            <button class="btn btn-outline-primary mt-3" @onclick="RefreshTime">
                <span class="bi bi-arrow-clockwise"></span> Refresh Time
            </button>
        </div>
    </div>
</div>

@code {
    private DateTime currentTime = DateTime.Now;

    private void RefreshTime()
    {
        currentTime = DateTime.Now;
    }

    private string GetGreetingMessage()
    {
        int hour = currentTime.Hour;
        if (hour < 12) return "Good Morning";
        if (hour < 18) return "Good Afternoon";
        return "Good Evening";
    }
}